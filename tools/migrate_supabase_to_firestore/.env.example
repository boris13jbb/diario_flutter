# URL del proyecto Supabase (Settings → API)
SUPABASE_URL=https://swirjlhuxcpcfuvketcv.supabase.co

# Service Role Key (Settings → API → service_role). NO la anon key.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# Ruta al JSON de cuenta de servicio de Firebase
# Console → Project Settings → Service accounts → Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# true = solo muestra qué haría, sin escribir en Firestore
DRY_RUN=false

# Modo 1 (recomendado): mapear Supabase UID → Firebase UID por email
AUTO_MAP_BY_EMAIL=true

# Modo 2: un solo usuario (si AUTO_MAP_BY_EMAIL=false)
# SUPABASE_USER_ID=e472e7e5-e58e-4893-bae5-5843aa805410
# FIREBASE_USER_ID=pega_aqui_tu_uid_de_firebase_auth

# Modo 3: mapa JSON manual (sobreescribe modo 2)
# UID_MAP_JSON={"uuid-supabase":"uid-firebase"}
